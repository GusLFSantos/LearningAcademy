<% content_for :title, "My Progress" %>

<div class="max-w-3xl mx-auto">
  <header class="flex items-end justify-between gap-4 mb-8">
    <div>
      <h1 class="text-3xl font-bold tracking-tight">My Progress</h1>
      <p class="text-gray-500 mt-1">Signed in as <span class="font-medium text-gray-900"><%= @user.name %></span></p>
    </div>
    <div class="text-right">
      <div class="text-2xl font-bold text-indigo-600"><%= humane_duration(@total_time) %></div>
      <div class="text-xs text-gray-400 uppercase tracking-wide">Total learning time</div>
    </div>
  </header>

  <!-- Badges -->
  <section class="mb-10">
    <h2 class="text-xl font-semibold mb-3">Badges</h2>
    <% if @badge_awards.any? %>
      <ul class="grid gap-4 sm:grid-cols-3">
        <% @badge_awards.each do |award| %>
          <li class="bg-white rounded-2xl border border-gray-200 p-5 text-center">
            <div class="text-4xl mb-2"><%= award.badge.icon.presence || "🏅" %></div>
            <div class="font-semibold"><%= award.badge.name %></div>
            <div class="text-xs text-gray-400 mt-1"><%= award.badge.course.title %></div>
            <div class="text-xs text-gray-400">Earned <%= award.awarded_at.to_date.to_fs(:long) %></div>
          </li>
        <% end %>
      </ul>
    <% else %>
      <div class="bg-white rounded-2xl border border-dashed border-gray-300 p-8 text-center text-gray-500">
        No badges yet — complete a course to earn one.
      </div>
    <% end %>
  </section>

  <!-- Enrolled courses -->
  <section>
    <h2 class="text-xl font-semibold mb-3">My Courses</h2>
    <% if @enrollments.any? %>
      <ul class="space-y-4">
        <% @enrollments.each do |enrollment| %>
          <% course = enrollment.course %>
          <% progress = course.progress_for(@user) %>
          <li class="bg-white rounded-2xl border border-gray-200 p-5">
            <div class="flex items-start justify-between gap-3 mb-3">
              <h3 class="font-semibold">
                <%= link_to course.title, course_path(course), class: "hover:text-indigo-600" %>
              </h3>
              <%= render "courses/status_badge", status: progress.status %>
            </div>
            <%= render "courses/progress_bar", course: course, progress: progress %>
            <div class="mt-3 flex items-center gap-4 text-xs text-gray-400">
              <span>🕒 <%= humane_duration(progress.time_spent_seconds) %> spent</span>
              <span>⏱️ ≈ <%= progress.estimated_minutes %> min total</span>
            </div>
          </li>
        <% end %>
      </ul>
    <% else %>
      <div class="bg-white rounded-2xl border border-dashed border-gray-300 p-8 text-center text-gray-500">
        You haven't enrolled in any courses yet.
        <%= link_to "Browse the catalog", courses_path, class: "text-indigo-600 hover:underline" %>.
      </div>
    <% end %>
  </section>
</div>
