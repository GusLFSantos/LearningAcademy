<% content_for :title, "Quiz · #{@lesson.title}" %>

<div class="max-w-2xl mx-auto">
  <%= link_to "← #{@lesson.title}", course_lesson_path(@course, @lesson),
        class: "text-sm text-slate-500 dark:text-slate-400 hover:text-indigo-600 dark:hover:text-indigo-400" %>

  <h1 class="text-2xl font-bold mt-3 mb-1">Quiz: <%= @lesson.title %></h1>
  <p class="text-slate-500 dark:text-slate-400 mb-6 text-sm">
    Score <%= @quiz.pass_percentage %>% or higher to complete this lesson.
  </p>

  <%= form_with url: course_lesson_quiz_attempts_path(@course, @lesson), method: :post do |f| %>
    <%= hidden_field_tag :started_at, Time.current.iso8601 %>

    <ol class="space-y-6">
      <% @questions.each_with_index do |question, qi| %>
        <li class="bg-white dark:bg-slate-900 rounded-xl border border-slate-200 dark:border-slate-800 p-5">
          <p class="font-medium mb-3">
            <span class="text-slate-400 dark:text-slate-500 mr-1"><%= qi + 1 %>.</span><%= question.prompt %>
          </p>
          <div class="space-y-2">
            <% question.answer_options.each do |opt| %>
              <label class="flex items-center gap-3 rounded-lg border border-slate-200 dark:border-slate-700 px-3 py-2 cursor-pointer hover:bg-slate-50 dark:hover:bg-slate-800 has-checked:border-indigo-400 dark:has-checked:border-indigo-500 has-checked:bg-indigo-50 dark:has-checked:bg-indigo-950/50 transition-colors">
                <%= radio_button_tag "answers[#{question.id}]", opt.id, false, required: true, class: "text-indigo-600" %>
                <span class="text-sm"><%= opt.body %></span>
              </label>
            <% end %>
          </div>
        </li>
      <% end %>
    </ol>

    <div class="mt-6">
      <%= f.submit "Submit answers",
            class: "rounded-xl bg-indigo-600 text-white text-sm font-semibold px-5 py-2.5 hover:bg-indigo-700 transition-colors cursor-pointer" %>
    </div>
  <% end %>
</div>
