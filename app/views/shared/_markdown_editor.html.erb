<%#
  Markdown textarea with a live server-rendered preview.
  Locals: f (form builder), field (symbol), label (string)
%>
<div data-controller="markdown-preview"
     data-markdown-preview-url-value="<%= markdown_preview_path %>"
     class="grid md:grid-cols-2 gap-4">
  <div>
    <%= f.label field, label, class: "block text-sm font-medium mb-1" %>
    <%= f.text_area field, rows: 16,
          data: { "markdown-preview-target": "input", action: "input->markdown-preview#update" },
          class: "w-full rounded-lg border border-gray-300 font-mono text-sm p-3 focus:ring-indigo-500 focus:border-indigo-500" %>
    <p class="text-xs text-gray-400 mt-1">Markdown supported — fenced code blocks and <code>```mermaid</code> diagrams.</p>
  </div>
  <div>
    <span class="block text-sm font-medium mb-1 text-gray-500">Preview</span>
    <div class="markdown-body border border-gray-200 rounded-lg p-3 min-h-64 bg-white overflow-auto"
         data-markdown-preview-target="output"></div>
  </div>
</div>
