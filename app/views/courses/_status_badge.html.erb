<%#
  Renders a progression status pill. Local: status (symbol/string).
%>
<% label, klass =
     case status.to_sym
     when :completed   then ["Completed",   "bg-emerald-100 dark:bg-emerald-900/50 text-emerald-700 dark:text-emerald-400"]
     when :in_progress then ["In progress",  "bg-amber-100 dark:bg-amber-900/50 text-amber-700 dark:text-amber-400"]
     else                   ["Not started",  "bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-400"]
     end %>
<span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium <%= klass %>">
  <%= label %>
</span>
