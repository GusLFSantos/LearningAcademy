<%= form_with model: course do |f| %>
  <%= render "shared/errors", record: course %>

  <div class="space-y-6">
    <div>
      <%= f.label :title, class: "block text-sm font-medium mb-1" %>
      <%= f.text_field :title, class: "w-full rounded-lg border border-gray-300 p-2.5 focus:ring-indigo-500 focus:border-indigo-500" %>
    </div>

    <div class="grid sm:grid-cols-2 gap-4">
      <div>
        <%= f.label :summary, class: "block text-sm font-medium mb-1" %>
        <%= f.text_field :summary, class: "w-full rounded-lg border border-gray-300 p-2.5" %>
      </div>
      <div>
        <%= f.label :position, "Order", class: "block text-sm font-medium mb-1" %>
        <%= f.number_field :position, class: "w-full rounded-lg border border-gray-300 p-2.5" %>
      </div>
    </div>

    <label class="inline-flex items-center gap-2 text-sm">
      <%= f.check_box :published, class: "rounded text-indigo-600" %>
      Published (visible in the catalog)
    </label>

    <%= render "shared/markdown_editor", f: f, field: :description, label: "Description (Markdown)" %>

    <fieldset class="border border-gray-200 rounded-xl p-4">
      <legend class="text-sm font-medium px-1">Completion badge</legend>
      <%= f.fields_for :badge do |bf| %>
        <div class="grid sm:grid-cols-3 gap-4">
          <div>
            <%= bf.label :name, class: "block text-sm font-medium mb-1" %>
            <%= bf.text_field :name, class: "w-full rounded-lg border border-gray-300 p-2.5" %>
          </div>
          <div>
            <%= bf.label :icon, "Icon (emoji)", class: "block text-sm font-medium mb-1" %>
            <%= bf.text_field :icon, class: "w-full rounded-lg border border-gray-300 p-2.5" %>
          </div>
          <div>
            <%= bf.label :description, class: "block text-sm font-medium mb-1" %>
            <%= bf.text_field :description, class: "w-full rounded-lg border border-gray-300 p-2.5" %>
          </div>
        </div>
      <% end %>
      <p class="text-xs text-gray-400 mt-2">Leave the name blank for no badge.</p>
    </fieldset>
  </div>

  <div class="mt-6 flex items-center gap-3">
    <%= f.submit class: "rounded-lg bg-indigo-600 text-white text-sm font-medium px-5 py-2.5 hover:bg-indigo-700 cursor-pointer" %>
    <%= link_to "Cancel", (course.persisted? ? course_path(course) : courses_path), class: "text-sm text-gray-500 hover:underline" %>
  </div>
<% end %>
