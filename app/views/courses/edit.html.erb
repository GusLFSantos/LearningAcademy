<% content_for :title, "Edit #{@course.title}" %>
<div class="max-w-3xl mx-auto">
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-bold">Edit Course</h1>
    <%= button_to "Delete course", course_path(@course), method: :delete,
          form: { data: { turbo_confirm: "Delete this course and all its lessons?" } },
          class: "text-sm text-red-600 hover:underline" %>
  </div>
  <%= render "form", course: @course %>
</div>
