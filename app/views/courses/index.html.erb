<% content_for :title, "Course Catalog" %>

<div class="mb-8 flex items-end justify-between gap-4">
  <div>
    <h1 class="text-3xl font-bold tracking-tight">Course Catalog</h1>
    <p class="text-gray-500 mt-1">Pick a course, work through the lessons, and earn your badge.</p>
  </div>
  <%= link_to "+ New course", new_course_path,
        class: "shrink-0 rounded-lg bg-indigo-600 text-white text-sm font-medium px-4 py-2 hover:bg-indigo-700" %>
</div>

<% if @courses.any? %>
  <ul class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
    <% @courses.each do |course| %>
      <% progress = course.progress_for(current_user) %>
      <li class="bg-white rounded-2xl border border-gray-200 p-5 flex flex-col gap-4 hover:shadow-md transition-shadow">
        <div class="flex items-start justify-between gap-3">
          <h2 class="font-semibold text-lg leading-snug">
            <%= link_to course.title, course_path(course), class: "hover:text-indigo-600" %>
          </h2>
          <%= render "courses/status_badge", status: progress.status %>
        </div>

        <p class="text-sm text-gray-500 flex-1"><%= course.summary %></p>

        <div class="flex items-center gap-3 text-xs text-gray-400">
          <span>📚 <%= pluralize(progress.total, "lesson") %></span>
          <span>⏱️ ≈ <%= progress.estimated_minutes %> min</span>
        </div>

        <% if progress.status != :not_started %>
          <%= render "courses/progress_bar", course: course, progress: progress %>
        <% end %>

        <%= link_to "View course", course_path(course),
              class: "mt-1 inline-flex justify-center rounded-lg bg-indigo-600 text-white text-sm font-medium px-4 py-2 hover:bg-indigo-700" %>
      </li>
    <% end %>
  </ul>
<% else %>
  <div class="bg-white rounded-2xl border border-dashed border-gray-300 p-12 text-center text-gray-500">
    No published courses yet. <%= link_to "Create one", new_course_path, class: "text-indigo-600 hover:underline" %>.
  </div>
<% end %>

<% if @drafts.any? %>
  <section class="mt-10">
    <h2 class="text-sm font-semibold uppercase tracking-wide text-gray-400 mb-3">Drafts</h2>
    <ul class="space-y-2">
      <% @drafts.each do |course| %>
        <li class="bg-white rounded-xl border border-dashed border-gray-300 p-4 flex items-center justify-between">
          <div>
            <span class="font-medium"><%= course.title %></span>
            <span class="ml-2 text-xs rounded-full bg-gray-100 text-gray-500 px-2 py-0.5">Draft</span>
          </div>
          <div class="flex items-center gap-3 text-sm">
            <%= link_to "Preview", course_path(course), class: "text-gray-500 hover:underline" %>
            <%= link_to "Edit", edit_course_path(course), class: "text-indigo-600 hover:underline" %>
          </div>
        </li>
      <% end %>
    </ul>
  </section>
<% end %>
